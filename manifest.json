{
  "manifest_version": 3,
  "name": "Afterglow",
  "version": "0.1.0",
  "description": "Retro display filters for any video: CRT, Game Boy, Game Boy Color, Virtual Boy, and PS1 shaders rendered in real time with WebGL.",
  "permissions": ["activeTab", "storage", "tabCapture"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["shaders/*.glsl"],
      "matches": ["<all_urls>"]
    }
  ]
}
